# plugin-kasa plugin environment
# Runtime values are loaded from test/config/plugins/plugin-kasa/.env(.local)
# or from process environment (docker-compose environment/env_file).

PLUGIN_KASA_ENABLED=true
PLUGIN_KASA_LOG_LEVEL=info

# Optional discovery tuning when UDP broadcast replies are blocked.
# KASA_DISCOVERY_SUBNETS supports CSV of CIDRs, /24 prefixes, or exact IPs.
# Examples: 192.168.88.0/24 or 192.168.88 or 192.168.88.74
KASA_DISCOVERY_ACTIVE=true
KASA_DISCOVERY_SUBNETS=
KASA_STATIC_IPS=
KASA_DISCOVERY_SCAN_INTERVAL_SEC=180
KASA_DISCOVERY_TIMEOUT_MS=400
KASA_DISCOVERY_CONCURRENCY=64
